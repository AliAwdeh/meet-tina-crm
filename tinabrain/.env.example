TINABRAIN_HOST=0.0.0.0
TINABRAIN_PORT=8010
TINABRAIN_ENV=development

CPM_API_BASE_URL=http://localhost:3001/api/v1
CPM_API_KEY=change-me
CPM_CALLBACK_SECRET=change-me
TINABRAIN_INBOUND_API_KEY=

OPENAI_API_KEY=change-me
TINABRAIN_MODEL=gpt-4.1-mini
TINABRAIN_TEMPERATURE=0.2
TINABRAIN_MAX_TOOL_ROUNDS=4
TINABRAIN_AUTO_CALLBACK=true

# off: never call n8n from TinaBrain
# always: forward requests to the external n8n webhook instead of generating internally
# tool: expose handoff_to_n8n as a model tool
TINABRAIN_N8N_MODE=off
TINABRAIN_N8N_WEBHOOK_URL=
TINABRAIN_N8N_API_KEY=
TINABRAIN_N8N_TIMEOUT_SECONDS=60
